{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "noEmit": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": true,
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "@motus/dictionary": ["packages/dictionary/src/index.ts"],
      "@motus/dictionary/*": ["packages/dictionary/src/*"],
      "@motus/game-core": ["packages/game-core/src/index.ts"],
      "@motus/protocol": ["packages/protocol/src/index.ts"],
      "@motus/ui": ["packages/ui/src/index.ts"]
    }
  }
}
